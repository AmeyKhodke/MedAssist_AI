# Pharmacy Agent - Environment Configuration Template
# Rename this file to .env and fill in your actual keys

# --- SECURITY ---
SECRET_KEY="your-super-secret-key-change-this"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- LLM SERVICES ---
# Get keys from https://groq.com/
GROQ_API_KEY="gsk_..."
# Get keys from https://aistudio.google.com/
GOOGLE_API="AIza..."

# --- MEMORY SERVICES ---
# Get keys from https://hindsight.vectorize.io/
HINDSIGHT_API_KEY="your-hindsight-key"
HINDSIGHT_BASE_URL="https://api.hindsight.vectorize.io"

# --- TRANSLATION SERVICES ---
# Get keys from https://sarvam.ai/
SARVAM_API_KEY="your-sarvam-key"

# --- EMAIL SERVICES (SMTP) ---
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-app-specific-password"

# --- DATABASE ---
DB_PATH="pharmacy.db"
